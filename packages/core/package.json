{
  "name": "@soulforge/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsc -b ../shared . && node dist/testing/runSyntheticConfirmedReferenceSmoke.js && node dist/testing/runV05FoundationSmoke.js && node dist/testing/runV05PersistSmoke.js && node dist/testing/runRealModOpenSmoke.js ../../mods",
    "test:native-preview": "tsc -b ../shared . && node dist/testing/runNativeInspectSmoke.js ../../mods",
    "test:reference-confidence": "tsc -b ../shared . && node dist/testing/runSyntheticConfirmedReferenceSmoke.js",
    "test:v05-foundation": "tsc -b ../shared . && node dist/testing/runV05FoundationSmoke.js && node dist/testing/runV05PersistSmoke.js",

    "mock-pipeline": "npm run build && node dist/testing/runMockPipelineCli.js"
  },
  "dependencies": {
    "@soulforge/shared": "0.0.0"
  }
}
