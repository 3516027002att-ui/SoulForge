{
  "name": "soulforge",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @soulforge/desktop",
    "build": "npm run build -w @soulforge/shared && npm run build -w @soulforge/core && npm run build -w @soulforge/desktop",
    "typecheck": "tsc -b packages/shared packages/core apps/desktop --pretty false",
    "test": "npm run test --workspaces --if-present && npm run test:desktop-security && npm run test:ui-localization && npm run test:progress-integrity && npm run test:native-gate-contract && npm run test:database-utility",
    "bridge:build": "node scripts/run-dotnet.mjs build bridge/SoulForge.Bridge/SoulForge.Bridge.csproj --nologo",
    "bridge:publish": "node scripts/run-dotnet.mjs publish bridge/SoulForge.Bridge/SoulForge.Bridge.csproj -c Release --nologo --self-contained true -r win-x64",
    "bridge:verify:synthetic": "node scripts/verify-synthetic-core-fixtures.mjs && npm run test:param-read-pagination -w @soulforge/core",
    "bridge:verify:daemon": "node scripts/verify-bridge-daemon.mjs",
    "bridge:verify:client": "npm run test:bridge-daemon-client -w @soulforge/core",
    "bridge:verify:crash": "npm run test:bridge-daemon-crash -w @soulforge/core",
    "bridge:verify:oodle": "node scripts/verify-oodle-runtime.mjs",
    "bridge:verify:oodle:real": "npm run bridge:build && node scripts/verify-real-oodle-krak.mjs",
    "bridge:verify:dcx-documents": "node scripts/verify-native-dcx-documents.mjs",
    "bridge:verify:bnd4-writer": "npm run test:native-bnd4-writer -w @soulforge/core",
    "bridge:verify:bnd4-transaction": "npm run test:native-bnd4-transaction -w @soulforge/core",
    "bridge:verify:fmg": "npm run test:native-fmg -w @soulforge/core",
    "bridge:verify:fmg:transaction": "npm run test:native-fmg-transaction -w @soulforge/core",
    "bridge:verify:param": "npm run test:native-param -w @soulforge/core",
    "bridge:verify:param:transaction": "npm run test:param-semantic-transaction -w @soulforge/core",
    "test:ai-fake-loop": "npm run test:ai-fake-loop -w @soulforge/core",
    "test:context-broker": "npm run test:context-broker -w @soulforge/core",
    "bridge:verify:emevd": "npm run test:native-emevd -w @soulforge/core",
    "bridge:verify:emevd:transaction": "npm run test:native-emevd-transaction -w @soulforge/core",
    "bridge:verify:emevd:corpus": "npm run build -w @soulforge/core && node scripts/verify-native-emevd-corpus.mjs",
    "bridge:verify:msb": "npm run test:native-msb -w @soulforge/core",
    "bridge:verify:msb:transaction": "npm run test:msb-semantic-transaction -w @soulforge/core",
    "test:asset-import": "npm run test:asset-import -w @soulforge/core",
    "test:editor-document-store": "npm run test:editor-document-store -w @soulforge/core",
    "test:model-service-vault-contract": "npm run test:model-service-vault-contract -w @soulforge/core",
    "test:hex-scene": "npm run test:hex-scene -w @soulforge/core",
    "test:scene-draw-list": "npm run test:scene-draw-list -w @soulforge/core",
    "test:asset-writeback": "npm run test:asset-writeback -w @soulforge/core",
    "test:vault-ipc-contract": "npm run test:vault-ipc-contract -w @soulforge/core",
    "test:three-scene-module": "npm run test:three-scene-module -w @soulforge/core",
    "test:emevd-four-view": "npm run test:emevd-four-view -w @soulforge/core",
    "test:dds-convert-writeback": "npm run test:dds-convert-writeback -w @soulforge/core",
    "test:vault-encrypt-contract": "npm run test:vault-encrypt-contract -w @soulforge/core",
    "test:openai-responses": "npm run test:openai-responses -w @soulforge/core",
    "test:workbench-projections": "npm run test:workbench-projections -w @soulforge/core",
    "test:resource-index-diagnostics": "npm run test:resource-index-diagnostics -w @soulforge/core",
    "test:paramdef-layout": "npm run test:paramdef-layout -w @soulforge/core",
    "test:param-field-mutation": "npm run test:param-field-mutation -w @soulforge/core",
    "test:param-read-pagination": "npm run test:param-read-pagination -w @soulforge/core",
    "test:emedf-schema": "npm run test:emedf-schema -w @soulforge/core",
    "test:emevd-ipc-contract": "npm run test:emevd-ipc-contract -w @soulforge/core",
    "test:emevd-envelope-map": "npm run test:emevd-envelope-map -w @soulforge/core",
    "test:fmg-msb-ipc-contract": "npm run test:fmg-msb-ipc-contract -w @soulforge/core",
    "test:param-msb-write-ipc-contract": "npm run test:param-msb-write-ipc-contract -w @soulforge/core",
    "test:desktop-live-editor-contract": "npm run test:desktop-live-editor-contract -w @soulforge/core",
    "test:param-duplicate-native": "npm run test:param-duplicate-native -w @soulforge/core",
    "test:scene-asset-inventory": "npm run test:scene-asset-inventory -w @soulforge/core",
    "test:flver-candidate": "npm run test:flver-candidate -w @soulforge/core",
    "test:performance-baseline": "npm run test:performance-baseline -w @soulforge/core",
    "test:release-content": "node scripts/verify-release-package-content.mjs",
    "test:private-native-gate": "node scripts/verify-private-native-gate.mjs",
    "test:private-native-gate:allow-skip": "node scripts/verify-private-native-gate.mjs --allow-skip",
    "test:section28-sekiro-gate": "node scripts/verify-section28-sekiro-gate.mjs",
    "test:section28-sekiro-gate:allow-skip": "node scripts/verify-section28-sekiro-gate.mjs --allow-skip",
    "test:portable-packaging-gate": "node scripts/verify-portable-packaging-gate.mjs",
    "test:native-preview": "npm run test:native-preview -w @soulforge/core",
    "test:desktop-security": "node scripts/verify-desktop-security.mjs",
    "test:ui-localization": "node scripts/verify-ui-localization.mjs",
    "test:progress-integrity": "node scripts/verify-progress-integrity.mjs",
    "test:native-gate-contract": "node scripts/verify-native-gate-contract.mjs",
    "test:native-fixture-registry": "node scripts/verify-native-fixture-registry.mjs",
    "test:database-utility": "npm run test:database-utility -w @soulforge/desktop",
    "test:sqlite-crash-recovery": "npm run test:sqlite-crash-recovery -w @soulforge/core",
    "codexpro:doctor": "codexpro doctor --root .",
    "codexpro:setup": "codexpro setup --root . --mode agent --write workspace --bash safe --bash-session soulforge --require-bash-session --tool-mode standard",
    "codexpro:start": "codexpro start --root . --mode agent --write workspace --bash safe --bash-session soulforge --require-bash-session --tool-mode standard",
    "codexpro:start:agent": "npm run codexpro:start",
    "codexpro:start:handoff": "codexpro start --root . --mode handoff --no-bash --tool-mode standard",
    "codexpro:pro-bundle": "codexpro pro-bundle --root .",
    "test:agent-history-utility-contract": "npm run test:agent-history-utility-contract -w @soulforge/core",
    "test:agent-loop-registry-contract": "npm run test:agent-loop-registry-contract -w @soulforge/core",
    "test:has-game-scene-inventory": "npm run test:has-game-scene-inventory -w @soulforge/core",
    "test:open-format-convert": "npm run test:open-format-convert -w @soulforge/core",
    "test:open-format-adapter-rules": "npm run test:open-format-adapter-rules -w @soulforge/core",
    "test:has-game-flver-candidate": "npm run test:has-game-flver-candidate -w @soulforge/core"
  },
  "devDependencies": {
    "@types/node": "^22.13.1",
    "codexpro": "0.28.5",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "app-builder-bin": "^5.0.0-alpha.10"
  }
}
